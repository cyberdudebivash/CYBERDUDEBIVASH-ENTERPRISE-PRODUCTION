{
  "name": "@titan/platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "db:migrations:apply:local": "wrangler d1 migrations apply titan-platform-db --local",
    "db:seed:local": "wrangler d1 execute titan-platform-db --local --file=./seed.sql",
    "db:backup:local": "node scripts/db-backup-local.mjs",
    "dev": "wrangler dev",
    "config:check:staging": "node scripts/check-wrangler-config.mjs --env staging",
    "config:check:production": "node scripts/check-wrangler-config.mjs --env production",
    "secrets:validate:local": "node scripts/validate-secrets.mjs --local",
    "secrets:validate:staging": "node scripts/validate-secrets.mjs --env staging",
    "secrets:validate:production": "node scripts/validate-secrets.mjs --env production",
    "smoke-test": "node scripts/smoke-test.mjs",
    "deploy:dry-run:staging": "wrangler deploy --dry-run --env staging",
    "deploy:dry-run:production": "wrangler deploy --dry-run --env production",
    "release:staging": "node scripts/release.mjs --env staging",
    "release:production": "node scripts/release.mjs --env production",
    "rollback:staging": "wrangler rollback --env staging",
    "rollback:production": "wrangler rollback --env production"
  },
  "dependencies": {
    "@auth/core": "0.41.2",
    "@auth/d1-adapter": "1.11.2",
    "@titan/assessment-core": "*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "@types/sql.js": "^1.4.9",
    "@vitest/coverage-v8": "^3.0.0",
    "sql.js": "^1.14.1",
    "vite": "^6.2.3",
    "vitest": "^3.0.0",
    "wrangler": "^4.112.0"
  }
}
