    "react-dom": "^19.0.1",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^25.0.1",
    "vite": "^6.2.3",
    "vitest": "^3.0.0"
  }
