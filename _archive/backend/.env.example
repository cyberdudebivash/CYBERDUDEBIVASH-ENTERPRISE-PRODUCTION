# CYBERDUDEBIVASH Backend Environment
# Copy this to .env and fill in your values

PORT=3001
NODE_ENV=production

# JWT Secret (change this to a long random string in production)
JWT_SECRET=cyberdudebivash_jwt_secret_change_this_in_production_2026

# Razorpay (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_REAL_KEY
RAZORPAY_KEY_SECRET=REPLACE_WITH_REAL_SECRET

# Frontend URL (for CORS)
FRONTEND_URL=https://www.cyberdudebivash.com

# Admin secret for internal operations
ADMIN_SECRET=REPLACE_WITH_STRONG_ADMIN_SECRET
